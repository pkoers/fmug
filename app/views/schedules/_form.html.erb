<% current_conferences = Conference.current_conference.order(:edition) %>
<% conference_options = current_conferences.any? ? current_conferences : Conference.order(edition: :asc) %>
<% form_title = schedule.persisted? ? "Edit schedule item" : "Add a schedule item" %>
<% form_description = schedule.persisted? ? "Update the timing or wording for this agenda block." : "Create one agenda block at a time. Pick the conference day, start time, duration, and write the session title or description visitors should see." %>

<%= form_with(model: schedule, class: "contents") do |form| %>
  <% if schedule.errors.any? %>
    <div id="error_explanation" class="mb-6 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-red-700 shadow-sm">
      <h2 class="font-semibold"><%= pluralize(schedule.errors.count, "error") %> prevented this schedule item from being saved:</h2>

      <ul class="mt-2 list-disc pl-5">
        <% schedule.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="w-full rounded-[28px] border border-stone-200 bg-white p-6 shadow-sm sm:p-8">
    <div class="mb-8">
      <p class="text-lg font-semibold uppercase tracking-[0.24em] text-stone-500">Agenda Builder</p>
      <h2 class="mt-2 text-5xl font-semibold text-stone-900"><%= form_title %></h2>
      <p class="mt-3 max-w-2xl text-xl leading-9 text-stone-600">
        <%= form_description %>
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      <div class="sm:col-span-2">
        <%= form.label :conference_id, "Conference", class: "block text-lg font-medium text-stone-800" %>
        <%= form.collection_select :conference_id, conference_options, :id, :edition, { prompt: "Select a conference" }, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-4 text-xl text-stone-900 shadow-sm outline-none transition focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-200" %>
        <% if current_conferences.any? %>
          <p class="mt-2 text-lg text-stone-500">Only the current conference can have agenda items.</p>
        <% else %>
          <p class="mt-2 text-lg text-amber-700">No current conference is set, so this form will fail validation until one conference is marked as current.</p>
        <% end %>
      </div>

      <div>
        <%= form.label :day, "Conference day", class: "block text-lg font-medium text-stone-800" %>
        <%= form.number_field :day, min: 1, placeholder: "1", class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-4 text-xl text-stone-900 shadow-sm outline-none transition focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-200" %>
        <p class="mt-2 text-lg text-stone-500">Use `1` for the first day, `2` for the second, and so on.</p>
      </div>

      <div>
        <%= form.label :time, "Start time", class: "block text-lg font-medium text-stone-800" %>
        <%= form.time_field :time, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-4 text-xl text-stone-900 shadow-sm outline-none transition focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-200" %>
        <p class="mt-2 text-lg text-stone-500">Shown in the public agenda as the session start.</p>
      </div>

      <div class="sm:col-span-2">
        <%= form.label :length, "Duration (minutes)", class: "block text-lg font-medium text-stone-800" %>
        <%= form.number_field :length, min: 5, step: 5, placeholder: "45", class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-4 text-xl text-stone-900 shadow-sm outline-none transition focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-200" %>
      </div>

      <div class="sm:col-span-2">
        <%= form.label :description, "Session title or description", class: "block text-lg font-medium text-stone-800" %>
        <%= form.text_area :description, rows: 5, placeholder: "Opening keynote, lunch break, panel discussion, workshop, closing remarks...", class: "mt-2 block w-full rounded-2xl border border-stone-300 bg-stone-50 px-4 py-4 text-xl text-stone-900 shadow-sm outline-none transition focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-200" %>
        <p class="mt-2 text-lg text-stone-500">Keep it short and scannable. This text is what attendees will read in the agenda.</p>
      </div>
    </div>

    <div class="mt-8 flex flex-col gap-3 border-t border-stone-200 pt-6 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-lg text-stone-500">Tip: create one item per session, break, or activity.</p>
      <div class="flex flex-col gap-3 sm:flex-row">
        <%= link_to "Back to schedules", schedules_path, class: "inline-flex items-center justify-center rounded-xl border border-stone-300 px-5 py-4 text-lg font-medium text-stone-700 transition hover:bg-stone-100" %>
        <%= form.submit class: "inline-flex cursor-pointer items-center justify-center rounded-xl bg-blue-600 px-6 py-4 text-lg font-semibold text-white transition hover:bg-blue-500" %>
      </div>
    </div>
  </div>
<% end %>
