<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Fmug" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@shoelace-style/shoelace@2.0.0/dist/themes/light.css">
    <script type="module" src="https://cdn.jsdelivr.net/npm/@shoelace-style/shoelace@2.0.0/dist/shoelace.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

    <link href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:400,700" rel="stylesheet" />
    <!-- Define your gradient here - use online tools to find a gradient matching your branding-->
    <style>
      .gradient {
        background: linear-gradient(90deg, #d53369 0%, #daae51 100%);
      }
    </style>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <main class="w-full mt-28 px-5 flex">
      <% if notice.present? || alert.present? %>
        <div id="flash-messages" class="fixed left-1/2 top-6 z-50 w-full max-w-xl -translate-x-1/2 px-5">
          <% if notice.present? %>
            <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-6 py-5 text-center text-2xl font-semibold text-emerald-900 shadow-sm"><%= notice %></div>
          <% end %>
          <% if alert.present? %>
            <div class="mt-3 rounded-2xl border border-red-200 bg-red-50 px-6 py-5 text-center text-2xl font-semibold text-red-900 shadow-sm"><%= alert %></div>
          <% end %>
        </div>
      <% end %>
      <%= yield %>
    </main>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const flashMessages = document.getElementById("flash-messages");

        if (!flashMessages) {
          return;
        }

        window.setTimeout(() => {
          flashMessages.remove();
        }, 10000);
      });
    </script>
  </body>
</html>
