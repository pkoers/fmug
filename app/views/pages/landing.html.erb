<% content_for :title, "FMUG Conferences" %>
<% current_conference = @current_conference %>
<% conference_title = if current_conference.present?
  "Conference #{current_conference.edition} | #{current_conference.start_date.strftime("%b %-d, %Y")} - #{current_conference.end_date.strftime("%b %-d, %Y")}"
end %>

<style>
  .landing-auth {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 12px;
  }

  .landing-auth__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    border: 1px solid #d6d3d1;
    background: #ffffff;
    color: #1c1917;
    padding: 12px 18px;
    font-size: 1.6rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
  }

  .landing-auth__button:hover {
    background: #f5f5f4;
  }

  .landing-auth__meta {
    color: #57534e;
    font-size: 1.5rem;
  }

  .registration-modal[hidden] {
    display: none;
  }

  .registration-modal {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(28, 25, 23, 0.45);
    padding: 24px;
  }

  .registration-modal__panel {
    width: min(100%, 520px);
    border-radius: 24px;
    background: #ffffff;
    padding: 28px;
    box-shadow: 0 24px 60px rgba(28, 25, 23, 0.18);
  }

  .registration-modal__title {
    font-size: 2.2rem;
    font-weight: 600;
    color: #1c1917;
  }

  .registration-modal__copy {
    margin-top: 10px;
    font-size: 1.5rem;
    color: #57534e;
  }

  .registration-modal__choice {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-top: 20px;
    font-size: 1.8rem;
    color: #44403c;
  }

  .registration-modal__actions {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    margin-top: 26px;
  }

  .registration-modal__error {
    margin-top: 16px;
    font-size: 1.4rem;
    color: #b91c1c;
  }

  .registration-modal__status {
    margin-top: 18px;
    border-radius: 18px;
    background: #f5f5f4;
    padding: 16px 18px;
    font-size: 1.5rem;
    color: #44403c;
  }

  sl-button.is-active::part(base) {
    background-color: lightgreen;
    color: #000;
  }
</style>

<div class="flex w-full flex-col space-y-8">
  <div class="landing-auth">
    <% if logged_in? %>
      <span class="landing-auth__meta">Signed in as <%= current_user.email %><%= " (Admin)" if current_user.admin? %></span>
      <%= button_to "Logout", logout_path, method: :delete, class: "landing-auth__button" %>
    <% elsif google_oauth_configured? %>
      <%= button_to "Login with Google", "/auth/google_oauth2", method: :post, class: "landing-auth__button" %>
    <% else %>
      <span class="landing-auth__meta">Google login is not configured yet.</span>
    <% end %>
  </div>

  <div class="flex w-full justify-center">
    <%= image_tag "fmug-400dpiLogo.jpeg", alt: "FMUG Logo", class: "mx-auto block h-auto max-h-[440px] w-auto max-w-full object-contain" %>
  </div>

  <%= render 'pages/about' %>

  <%= render 'pages/current' %>

  <div id="schedule-section" class="mt-10" style="display: none;">
    <%= render template: "schedules/agenda" %>
  </div>

  <div class="h-12 w-full"></div>

  <div class="flex flex-row justify-center gap-8">

    <%= render 'pages/upcoming' %>

  </div>
</div>

<div id="self-registration-modal" class="registration-modal" hidden>
  <div class="registration-modal__panel" role="dialog" aria-modal="true" aria-labelledby="self-registration-title">
    <h2 id="self-registration-title" class="registration-modal__title"><%= conference_title %></h2>
    <div id="self-registration-create-panel">
      <p class="registration-modal__copy">How would you like to attend this conference?</p>

      <%= form_with scope: :registration, url: registration_path, method: :post, local: true, id: "self-registration-form" do |form| %>
        <label class="registration-modal__choice" for="attendance-physical-option">
          <input type="radio" name="attendance_mode_choice" id="attendance-physical-option" class="h-6 w-6 border-stone-300 text-blue-600 focus:ring-blue-500" />
          <span>Attend physically</span>
        </label>

        <label class="registration-modal__choice" for="attendance-online-option">
          <input type="radio" name="attendance_mode_choice" id="attendance-online-option" class="h-6 w-6 border-stone-300 text-blue-600 focus:ring-blue-500" />
          <span>Attend online</span>
        </label>

        <%= form.hidden_field :attendance_mode, id: "attendance-mode-value" %>

        <p id="self-registration-error" class="registration-modal__error" hidden>Please choose either physical or online attendance to continue.</p>

        <div class="registration-modal__actions">
          <button type="button" id="self-registration-cancel" class="landing-auth__button">Cancel</button>
          <button type="submit" id="self-registration-continue" class="landing-auth__button">Continue</button>
        </div>
      <% end %>
    </div>

    <div id="self-registration-remove-panel" hidden>
      <p class="registration-modal__copy">You are already registered for this conference.</p>
      <div class="registration-modal__status">
        Current attendance: <strong><%= @current_registration&.attending_physically? ? "Physical" : "Online" %></strong>
      </div>

      <div class="registration-modal__actions">
        <button type="button" id="self-registration-remove-cancel" class="landing-auth__button">Keep registration</button>
        <%= button_to "Remove registration", registration_path, method: :delete, class: "landing-auth__button" %>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const alreadyRegistered = <%= @current_registration.present? ? "true" : "false" %>;
    const registerButton = document.getElementById("register-button");
    const registerSection = document.getElementById("register-section");
    const registerSelfOption = document.getElementById("register-self-option");
    const inviteOtherOption = document.getElementById("invite-other-option");
    const registrationNextButton = document.getElementById("registration-next-button");
    const scheduleButton = document.getElementById("schedule-button");
    const scheduleSection = document.getElementById("schedule-section");
    const selfRegistrationModal = document.getElementById("self-registration-modal");
    const selfRegistrationCancel = document.getElementById("self-registration-cancel");
    const selfRegistrationRemoveCancel = document.getElementById("self-registration-remove-cancel");
    const selfRegistrationContinue = document.getElementById("self-registration-continue");
    const selfRegistrationError = document.getElementById("self-registration-error");
    const attendancePhysicalOption = document.getElementById("attendance-physical-option");
    const attendanceOnlineOption = document.getElementById("attendance-online-option");
    const attendanceModeValue = document.getElementById("attendance-mode-value");
    const selfRegistrationCreatePanel = document.getElementById("self-registration-create-panel");
    const selfRegistrationRemovePanel = document.getElementById("self-registration-remove-panel");
    const selfRegistrationForm = document.getElementById("self-registration-form");

    const closeSelfRegistrationModal = () => {
      if (!selfRegistrationModal) {
        return;
      }

      selfRegistrationModal.hidden = true;
    };

    const openSelfRegistrationModal = () => {
      if (!selfRegistrationModal) {
        return;
      }

      if (selfRegistrationError) {
        selfRegistrationError.hidden = true;
      }

      if (selfRegistrationCreatePanel && selfRegistrationRemovePanel) {
        selfRegistrationCreatePanel.hidden = alreadyRegistered;
        selfRegistrationRemovePanel.hidden = !alreadyRegistered;
      }

      selfRegistrationModal.hidden = false;
    };

    if (registerButton && registerSection) {
      registerButton.addEventListener("click", () => {
        const isHidden = registerSection.classList.contains("hidden");

        registerSection.classList.toggle("hidden", !isHidden);
        registerButton.classList.toggle("is-active", isHidden);
      });
    }

    if (scheduleButton && scheduleSection && !scheduleButton.hasAttribute("disabled")) {
      scheduleButton.addEventListener("click", () => {
        const isHidden = scheduleSection.style.display === "none";

        if (isHidden) {
          scheduleSection.style.display = "block";
          scheduleButton.classList.add("is-active");
          scheduleSection.scrollIntoView({ behavior: "smooth" });
        } else {
          scheduleSection.style.display = "none";
          scheduleButton.classList.remove("is-active");
        }
      });
    }

    if (registrationNextButton && registerSelfOption) {
      registrationNextButton.addEventListener("click", () => {
        if (registerSelfOption.checked) {
          openSelfRegistrationModal();
          return;
        }

        if (inviteOtherOption?.checked) {
          return;
        }
      });
    }

    selfRegistrationCancel?.addEventListener("click", closeSelfRegistrationModal);
    selfRegistrationRemoveCancel?.addEventListener("click", closeSelfRegistrationModal);
    selfRegistrationForm?.addEventListener("submit", (event) => {
      if (attendancePhysicalOption?.checked) {
        if (attendanceModeValue) {
          attendanceModeValue.value = "physical";
        }

        return;
      }

      if (attendanceOnlineOption?.checked) {
        if (attendanceModeValue) {
          attendanceModeValue.value = "online";
        }

        return;
      }

      event.preventDefault();

      if (selfRegistrationError) {
        selfRegistrationError.hidden = false;
      }
    });

    selfRegistrationModal?.addEventListener("click", (event) => {
      if (event.target === selfRegistrationModal) {
        closeSelfRegistrationModal();
      }
    });
  });
</script>
