<%= form_with(model: conference, class: "contents") do |form| %>
  <% if conference.errors.any? %>
    <div id="error_explanation" class="mb-6 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-red-700 shadow-sm">
      <h2 class="font-semibold"><%= pluralize(conference.errors.count, "error") %> prevented this conference from being saved:</h2>

      <ul class="mt-2 list-disc pl-5">
        <% conference.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% form_title = conference.persisted? ? "Edit conference" : "Add a conference" %>
  <% form_description = conference.persisted? ? "Update the dates, host, location, or current-conference status for this event." : "Create a conference record with its dates, host, location, and whether it should be treated as the current conference." %>

  <div class="w-full rounded-[28px] border border-stone-200 bg-white p-6 shadow-sm sm:p-8">
    <div class="mb-8">
      <p class="text-lg font-semibold uppercase tracking-[0.24em] text-stone-500">Conference Admin</p>
      <h2 class="mt-2 text-5xl font-semibold text-stone-900"><%= form_title %></h2>
      <p class="mt-3 max-w-2xl text-xl leading-9 text-stone-600"><%= form_description %></p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      <div>
        <%= form.label :edition, class: "block text-lg font-medium text-stone-800" %>
        <%= form.number_field :edition, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-4 text-xl text-stone-900 shadow-sm outline-none transition focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-200" %>
      </div>

      <div class="sm:col-span-2 grid gap-6 sm:grid-cols-2">
        <div>
          <%= form.label :start_date, class: "block text-lg font-medium text-stone-800" %>
          <%= form.date_field :start_date, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-4 text-xl text-stone-900 shadow-sm outline-none transition focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-200" %>
        </div>

        <div>
          <%= form.label :end_date, class: "block text-lg font-medium text-stone-800" %>
          <%= form.date_field :end_date, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-4 text-xl text-stone-900 shadow-sm outline-none transition focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-200" %>
        </div>
      </div>

      <div class="sm:col-span-2">
        <%= form.label :host, class: "block text-lg font-medium text-stone-800" %>
        <%= form.text_field :host, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-4 text-xl text-stone-900 shadow-sm outline-none transition focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-200" %>
      </div>

      <div class="sm:col-span-2">
        <%= form.label :location, class: "block text-lg font-medium text-stone-800" %>
        <%= form.text_area :location, rows: 4, class: "mt-2 block w-full rounded-2xl border border-stone-300 bg-stone-50 px-4 py-4 text-xl text-stone-900 shadow-sm outline-none transition focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-200" %>
      </div>

      <div class="sm:col-span-2">
        <%= form.label :image, "Conference image", class: "block text-lg font-medium text-stone-800" %>
        <% if conference.image.attached? %>
          <div class="mt-3">
            <%= image_tag conference.image, alt: "Conference image preview", class: "w-full max-w-xs rounded-2xl object-cover shadow-sm" %>
          </div>
        <% end %>
        <%= form.file_field :image, accept: "image/png,image/jpeg,image/webp", class: "mt-3 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-4 text-lg text-stone-900 shadow-sm outline-none transition focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-200" %>
        <p class="mt-2 text-lg text-stone-500">Upload an image for this conference. If none is uploaded, the public pages will keep the placeholder image.</p>
      </div>

      <div class="sm:col-span-2 rounded-2xl bg-stone-100 px-5 py-4">
        <label class="flex items-center gap-4 text-lg font-medium text-stone-800">
          <%= form.check_box :current, class: "h-6 w-6 rounded border border-stone-300 shadow-sm" %>
          <span>Mark this as the current conference</span>
        </label>
        <p class="mt-2 text-lg text-stone-500">Only one conference can be current at a time.</p>
      </div>
    </div>

    <div class="mt-8 flex flex-col gap-3 border-t border-stone-200 pt-6 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-lg text-stone-500">Set the current flag only for the conference that should power the public landing page.</p>
      <div class="flex flex-col gap-3 sm:flex-row">
        <%= link_to "Back to conferences", conferences_path, class: "inline-flex items-center justify-center rounded-xl border border-stone-300 px-5 py-4 text-lg font-medium text-stone-700 transition hover:bg-stone-100" %>
        <% if conference.persisted? %>
          <%= link_to "Show conference", conference, class: "inline-flex items-center justify-center rounded-xl border border-stone-300 px-5 py-4 text-lg font-medium text-stone-700 transition hover:bg-stone-100" %>
        <% end %>
        <%= form.submit class: "inline-flex cursor-pointer items-center justify-center rounded-xl bg-blue-600 px-6 py-4 text-lg font-semibold text-white transition hover:bg-blue-500" %>
      </div>
    </div>
  </div>
<% end %>
