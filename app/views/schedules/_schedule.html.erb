<div id="<%= dom_id schedule %>" class="w-full">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-center gap-3">
      <span class="inline-flex rounded-full bg-blue-100 px-4 py-2 text-base font-semibold uppercase tracking-[0.2em] text-blue-800">
        Conference <%= schedule.conference.edition %>
      </span>
      <span class="inline-flex rounded-full bg-stone-200 px-4 py-2 text-base font-medium text-stone-700">
        Day <%= schedule.day %>
      </span>
    </div>

    <div>
      <h2 class="text-3xl font-semibold text-stone-900">
        <%= schedule.description.presence || "Untitled schedule item" %>
      </h2>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
      <div class="rounded-2xl bg-stone-100 px-4 py-3">
        <p class="text-base font-semibold uppercase tracking-[0.16em] text-stone-500">Start time</p>
        <p class="mt-1 text-xl font-medium text-stone-900"><%= schedule.time.strftime("%H:%M") %></p>
      </div>
      <div class="rounded-2xl bg-stone-100 px-4 py-3">
        <p class="text-base font-semibold uppercase tracking-[0.16em] text-stone-500">Duration</p>
        <p class="mt-1 text-xl font-medium text-stone-900"><%= schedule.length %> minutes</p>
      </div>
      <div class="rounded-2xl bg-stone-100 px-4 py-3">
        <p class="text-base font-semibold uppercase tracking-[0.16em] text-stone-500">Conference day</p>
        <p class="mt-1 text-xl font-medium text-stone-900">Day <%= schedule.day %></p>
      </div>
    </div>
  </div>
</div>
