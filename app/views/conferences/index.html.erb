<% content_for :title, "Conferences" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="mb-6 inline-block rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 font-medium text-emerald-700" id="notice"><%= notice %></p>
  <% end %>

  <section class="rounded-[32px] bg-stone-50 p-6 shadow-sm ring-1 ring-stone-200 sm:p-8">
    <div class="flex flex-col gap-4 border-b border-stone-200 pb-6 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-lg font-semibold uppercase tracking-[0.24em] text-stone-500">Conference Admin</p>
        <h1 class="mt-2 text-6xl font-semibold tracking-tight text-stone-900">Manage conferences</h1>
        <p class="mt-3 max-w-2xl text-xl leading-9 text-stone-600">
          Review each conference, update dates and host details, and keep track of which conference is currently active.
        </p>
      </div>
      <%= link_to "New conference", new_conference_path, class: "inline-flex items-center justify-center rounded-xl bg-blue-600 px-6 py-4 text-lg font-semibold text-white transition hover:bg-blue-500" %>
    </div>

    <div id="conferences" class="mt-6 space-y-4">
      <% if @conferences.any? %>
        <% @conferences.each do |conference| %>
          <article class="rounded-[28px] border border-stone-200 bg-white p-5 shadow-sm sm:p-6">
            <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
              <%= render conference %>
              <div class="flex w-full flex-col gap-3 lg:w-auto lg:min-w-44">
                <%= link_to "Show", conference, class: "inline-flex items-center justify-center rounded-xl border border-stone-300 px-5 py-4 text-lg font-medium text-stone-700 transition hover:bg-stone-100" %>
                <%= link_to "Edit", edit_conference_path(conference), class: "inline-flex items-center justify-center rounded-xl border border-stone-300 px-5 py-4 text-lg font-medium text-stone-700 transition hover:bg-stone-100" %>
                <%= button_to "Delete", conference, method: :delete, class: "inline-flex w-full items-center justify-center rounded-xl bg-red-600 px-5 py-4 text-lg font-semibold text-white transition hover:bg-red-500", data: { turbo_confirm: "Delete this conference?" } %>
              </div>
            </div>
          </article>
        <% end %>
      <% else %>
        <div class="rounded-[28px] border border-dashed border-stone-300 bg-white px-6 py-16 text-center">
          <h2 class="text-4xl font-semibold text-stone-900">No conferences yet</h2>
          <p class="mx-auto mt-3 max-w-xl text-xl leading-9 text-stone-600">
            Create your first conference to start managing upcoming editions, dates, locations, and the current conference flag.
          </p>
          <%= link_to "Create the first conference", new_conference_path, class: "mt-6 inline-flex items-center justify-center rounded-xl bg-blue-600 px-6 py-4 text-lg font-semibold text-white transition hover:bg-blue-500" %>
        </div>
      <% end %>
    </div>
  </section>
</div>
